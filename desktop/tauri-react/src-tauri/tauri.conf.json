{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicKit Design",
  "version": "0.21.1",
  "identifier": "com.winterop.musickit.react",
  "build": {
    "frontendDist": "../../react"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MusicKit Design",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Music",
    "shortDescription": "MusicKit design-v2 prototype",
    "longDescription": "Desktop wrapper around the in-progress MusicKit redesign (Claude Designer output). Installs side-by-side with the production MusicKit app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
