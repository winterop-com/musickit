{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicKit",
  "version": "0.23.7",
  "identifier": "com.winterop.musickit",
  "build": {
    "frontendDist": "../../react"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MusicKit",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http: https:; media-src 'self' blob: http: https:; connect-src 'self' http: https: ws: wss:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Music",
    "shortDescription": "MusicKit desktop client",
    "longDescription": "Native desktop wrapper around the MusicKit web UI. Connects to a musickit serve instance over LAN or Tailscale and plays your library.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
