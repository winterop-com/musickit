{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicKit",
  "version": "0.13.17",
  "identifier": "com.winterop.musickit",
  "build": {
    "frontendDist": "../../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MusicKit",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Music",
    "shortDescription": "MusicKit desktop client",
    "longDescription": "Native desktop wrapper around the MusicKit web UI. Connects to a musickit serve instance over LAN or Tailscale and plays your library.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
