{
  "name": "musickit-desktop-electron",
  "version": "0.13.16",
  "description": "Electron sibling of the MusicKit desktop wrapper \u2014 for comparison with the Tauri build.",
  "main": "src/main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish=never",
    "build:mac": "electron-builder --mac --publish=never",
    "build:linux": "electron-builder --linux --publish=never",
    "build:win": "electron-builder --win --publish=never"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.winterop.musickit.electron",
    "productName": "MusicKit",
    "artifactName": "MusicKit-Electron-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "../frontend/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend",
        "to": "frontend"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "../tauri/src-tauri/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Audio",
      "icon": "../tauri/src-tauri/icons/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "icon": "../tauri/src-tauri/icons/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
